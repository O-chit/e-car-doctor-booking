# ===========================================
# Gmail Credentials for Booking Notifications
# ===========================================
# 
# To get a Gmail App Password:
# 1. Go to your Google Account → Security
# 2. Enable 2-Step Verification (if not already enabled)
# 3. Go to "App passwords" (under 2-Step Verification)
# 4. Select "Mail" and your device, then generate
# 5. Copy the 16-character password below
#
# IMPORTANT: Do NOT use your regular Gmail password!
# Use an App Password generated by Google.
#
# Then copy this file to .env and fill in your credentials:
#   cp .env.example .env

# Your Gmail address used to send booking notifications
# Example: your-email@gmail.com
EMAIL_USER=ecardoctor3gmail.com

# Gmail App Password (16 characters, no spaces)
# Generate this: Google Account → Security → App passwords
EMAIL_PASS=lisdkgndtyugmbos

# Email address where booking notifications will be sent
NOTIFICATION_EMAIL=ecardoctor3@gmail.com
